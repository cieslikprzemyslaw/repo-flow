{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-flow.schema.json",
  "title": "RepoFlow configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "issues",
    "git",
    "agent",
    "pullRequest",
    "messages",
    "ci",
    "reviewFeedback"
  ],
  "oneOf": [
    {
      "required": [
        "repository"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "repositories"
            ]
          },
          {
            "required": [
              "defaultRepository"
            ]
          }
        ]
      }
    },
    {
      "required": [
        "repositories",
        "defaultRepository"
      ],
      "not": {
        "required": [
          "repository"
        ]
      }
    }
  ],
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "localPath",
        "slug",
        "expectedOrigins",
        "baseBranch"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "localPath": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "expectedOrigins": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "baseBranch": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "legacyRepository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "expectedOrigins",
        "baseBranch"
      ],
      "properties": {
        "localPath": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "expectedOrigins": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "baseBranch": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "$ref": "#/$defs/legacyRepository"
    },
    "defaultRepository": {
      "type": "string",
      "minLength": 1
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repository"
      }
    },
    "issues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestPath"
      ],
      "properties": {
        "manifestPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requireCleanWorkingTree",
        "deleteMergedLocalBranches",
        "pruneRemoteReferences",
        "signOffCommits",
        "preCommitFixAttempts"
      ],
      "properties": {
        "requireCleanWorkingTree": {
          "type": "boolean"
        },
        "deleteMergedLocalBranches": {
          "type": "boolean"
        },
        "pruneRemoteReferences": {
          "type": "boolean"
        },
        "signOffCommits": {
          "type": "boolean"
        },
        "preCommitFixAttempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "command",
        "model",
        "minimumCliVersion",
        "heartbeatSeconds",
        "reasoningEffort",
        "ciFixReasoningEffort",
        "preCommitFixReasoningEffort",
        "runProjectChecks"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "codex",
            "claude"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "minimumCliVersion": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "heartbeatSeconds": {
          "type": "integer",
          "minimum": 5,
          "maximum": 300
        },
        "reasoningEffort": {
          "type": "string",
          "enum": [
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "ciFixReasoningEffort": {
          "type": "string",
          "enum": [
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "preCommitFixReasoningEffort": {
          "type": "string",
          "enum": [
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "runProjectChecks": {
          "type": "boolean"
        },
        "noActivityWarningSeconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 7200
        }
      }
    },
    "pullRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createDraft",
        "templatePath",
        "mergeMethod",
        "deleteBranchOnMerge"
      ],
      "properties": {
        "createDraft": {
          "type": "boolean"
        },
        "templatePath": {
          "type": "string",
          "minLength": 1
        },
        "mergeMethod": {
          "type": "string",
          "enum": [
            "squash",
            "merge",
            "rebase"
          ]
        },
        "deleteBranchOnMerge": {
          "type": "boolean"
        }
      }
    },
    "messages": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initialCommit",
        "reviewCommit",
        "ciFixCommit",
        "pullRequestTitle"
      ],
      "properties": {
        "initialCommit": {
          "type": "string",
          "minLength": 1
        },
        "reviewCommit": {
          "type": "string",
          "minLength": 1
        },
        "ciFixCommit": {
          "type": "string",
          "minLength": 1
        },
        "pullRequestTitle": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "pollSeconds",
        "timeoutSeconds",
        "autoFixAttempts"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "skip",
            "observe",
            "require-passing"
          ]
        },
        "pollSeconds": {
          "type": "integer",
          "minimum": 10,
          "maximum": 300
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 7200
        },
        "autoFixAttempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      }
    },
    "reviewFeedback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "confirmBeforeRun",
        "trustedAssociations"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "confirmBeforeRun": {
          "type": "boolean"
        },
        "trustedAssociations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "OWNER",
              "MEMBER",
              "COLLABORATOR"
            ]
          }
        },
        "maxReviewCycles": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "maxRepairCycles": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        }
      }
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "provider",
        "command",
        "model",
        "reasoningEffort",
        "heartbeatSeconds",
        "noActivityWarningSeconds",
        "timeoutSeconds"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "local",
            "external"
          ]
        },
        "provider": {
          "type": "string",
          "enum": [
            "codex",
            "claude"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "reasoningEffort": {
          "type": "string",
          "enum": [
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "heartbeatSeconds": {
          "type": "integer",
          "minimum": 5,
          "maximum": 300
        },
        "noActivityWarningSeconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 7200
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 7200
        }
      }
    }
  }
}
